---
/**
 * Hero Section — demo8 glassmorphism aesthetic
 *
 * Desktop: editorial two-column split
 *   Left  → eyebrow · headline · subhead · stat chips · pill CTAs
 *   Right → property image stack (main + secondary + floating card)
 * Mobile: single column, centered, visual hidden
 */

import { useTranslations } from '@/i18n';
import type { Lang } from '@/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="hero" class="hero" aria-label={t('hero.headline')}>

  <!-- Background radial glow — matches demo8 -->
  <div class="hero-bg-gradient" aria-hidden="true"></div>

  <div class="hero-container">
    <div class="hero-grid">

      <!-- ─── Left: Lean editorial text ──────────────────────── -->
      <div class="hero-inner">

        <span class="hero-eyebrow">
          <span class="eyebrow-dot" aria-hidden="true"></span>
          {t('hero.eyebrow')}
        </span>

        <h1 class="hero-headline">{t('hero.headline')}</h1>

        <p class="hero-subhead">{t('hero.subheadline')}</p>

        <!-- Two compact stat chips instead of a long bullet list -->
        <div class="hero-stats" aria-label="Key highlights">
          <div class="stat-chip">
            <strong class="stat-num">247+</strong>
            <span class="stat-lbl">{t('hero.stat1Label')}</span>
          </div>
          <div class="stat-divider" aria-hidden="true"></div>
          <div class="stat-chip">
            <strong class="stat-num">EN · ES</strong>
            <span class="stat-lbl">{t('hero.stat2Label')}</span>
          </div>
        </div>

        <!-- Pill CTA buttons -->
        <div class="hero-actions">
          <a href="#intent-selection" class="intent-btn intent-primary">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            {t('hero.ctaBuying')}
          </a>
          <a href="#intent-selection" class="intent-btn intent-secondary">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
            {t('hero.ctaSelling')}
          </a>
        </div>

      </div><!-- /hero-inner -->

      <!-- ─── Right: Property image stack (demo8 pattern) ────── -->
      <div class="hero-visual" aria-hidden="true">
        <div class="image-stack">

          <!-- Decorative accent ring -->
          <div class="accent-ring"></div>

          <!-- Accent dot grid -->
          <div class="accent-dots">
            <span></span><span></span><span></span>
            <span></span><span></span><span></span>
            <span></span><span></span><span></span>
          </div>

          <!-- Main property image — luxury exterior -->
          <div class="img-main">
            <img
              src="https://images.unsplash.com/photo-1613490493576-7fde63acd811?w=800&h=600&fit=crop&auto=format"
              alt="Beautiful Tampa Bay luxury home exterior"
              width="800"
              height="600"
              loading="eager"
            />
          </div>

          <!-- Secondary interior photo — overlapping -->
          <div class="img-secondary">
            <img
              src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=500&h=400&fit=crop&auto=format"
              alt="Modern home interior"
              width="500"
              height="400"
              loading="lazy"
            />
          </div>

          <!-- Floating glass card -->
          <div class="floating-card">
            <span class="card-label">{t('hero.cardLabel')}</span>
            <span class="card-value">Tampa Bay</span>
          </div>

        </div>
      </div><!-- /hero-visual -->

    </div><!-- /hero-grid -->
  </div><!-- /hero-container -->

</section>

<style>
  /* ─── Section ─────────────────────────────────────────────── */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    /* Space below fixed header (header ≈ 90px on desktop) */
    padding-top: 90px;
    padding-bottom: var(--space-xl);
    background: linear-gradient(
      155deg,
      var(--color-cream-warm) 0%,
      var(--color-cream) 55%,
      var(--color-cream-white) 100%
    );
  }

  /* ─── Radial glow (matches demo8 .hero-bg-gradient) ─────── */
  .hero-bg-gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 75% 55% at 15% 45%, rgba(212, 165, 165, 0.14) 0%, transparent 55%),
      radial-gradient(ellipse 55% 45% at 80% 55%, rgba(201, 168, 124, 0.09) 0%, transparent 45%);
    pointer-events: none;
    z-index: 0;
  }

  /* ─── Container ──────────────────────────────────────────── */
  .hero-container {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding-inline: var(--space-md);
  }

  /* ─── Two-column 50/50 grid ──────────────────────────────── */
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  /* ─── Left column ────────────────────────────────────────── */
  .hero-inner {
    max-width: 560px;
  }

  /* ─── Eyebrow badge ──────────────────────────────────────── */
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.4rem 1rem 0.4rem 0.75rem;
    background: rgba(255, 255, 255, 0.62);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: var(--radius-full);
    border: 1px solid rgba(183, 110, 121, 0.14);
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-charcoal);
    margin-bottom: 1.5rem;
  }

  .eyebrow-dot {
    width: 7px;
    height: 7px;
    background: var(--color-primary);
    border-radius: 50%;
    flex-shrink: 0;
    animation: pulse 2.4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1;   transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(0.75); }
  }

  /* ─── Headline ───────────────────────────────────────────── */
  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4.2vw, 3.75rem);
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: 0.01em;
    color: var(--color-black);
    margin-bottom: 1.25rem;
  }

  /* ─── Subhead ────────────────────────────────────────────── */
  .hero-subhead {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--color-charcoal-soft);
    margin-bottom: 2rem;
    max-width: 420px;
  }

  /* ─── Stat chips ─────────────────────────────────────────── */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 2.25rem;
  }

  .stat-chip {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .stat-num {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 500;
    color: var(--color-primary);
    line-height: 1;
  }

  .stat-lbl {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-charcoal-soft);
  }

  .stat-divider {
    width: 1px;
    height: 36px;
    background: linear-gradient(to bottom, transparent, rgba(183, 110, 121, 0.25), transparent);
  }

  /* ─── CTA pill buttons ───────────────────────────────────── */
  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .intent-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.5rem;
    border-radius: var(--radius-full);
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.92rem;
    text-decoration: none;
    min-height: 48px;
    min-width: 44px;
    white-space: nowrap;
    transition: all var(--duration-fast) var(--ease-smooth);
  }

  .intent-btn svg {
    width: 17px;
    height: 17px;
    flex-shrink: 0;
  }

  /* Primary — rose gold filled */
  .intent-primary {
    background: var(--color-primary);
    border: 1px solid var(--color-primary);
    color: #fff;
  }

  .intent-primary svg {
    stroke: #fff;
    opacity: 0.9;
  }

  .intent-primary:hover {
    background: var(--color-primary-dark);
    border-color: var(--color-primary-dark);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(183, 110, 121, 0.28);
  }

  /* Secondary — glass outline */
  .intent-secondary {
    background: rgba(255, 255, 255, 0.68);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(183, 110, 121, 0.18);
    color: var(--color-charcoal);
  }

  .intent-secondary:hover {
    background: rgba(255, 255, 255, 0.92);
    border-color: rgba(183, 110, 121, 0.35);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(183, 110, 121, 0.12);
  }

  .intent-btn:focus-visible {
    outline: 2px solid var(--color-secondary);
    outline-offset: 3px;
  }

  /* ─── Right column (visual) ──────────────────────────────── */
  .hero-visual {
    position: relative;
    overflow: visible;
    /* Prevent floating-card from causing horizontal page scroll */
    padding-right: 12px;
  }

  /* ─── Image stack — mirrors demo8 exactly ────────────────── */
  .image-stack {
    position: relative;
    height: 500px;
  }

  /* Main property image — top-right, large */
  .img-main {
    position: absolute;
    top: 0;
    right: 0;
    width: 85%;
    height: 340px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 20px 50px rgba(183, 110, 121, 0.15);
    z-index: 2;
  }

  .img-main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 6s ease;
  }

  .img-main:hover img {
    transform: scale(1.04);
  }

  /* Secondary interior image — bottom-left, overlapping */
  .img-secondary {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 52%;
    height: 230px;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 12px 36px rgba(183, 110, 121, 0.12);
    border: 4px solid #fff;
    z-index: 3;
  }

  .img-secondary img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Floating glass stat card */
  .floating-card {
    position: absolute;
    bottom: 52px;
    right: -8px;
    padding: 1.1rem 1.4rem;
    border-radius: var(--radius-md);
    z-index: 4;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.85);
    box-shadow: 0 8px 32px rgba(183, 110, 121, 0.1);
    animation: floatUp 4s ease-in-out infinite;
  }

  .card-label {
    font-family: var(--font-body);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-charcoal-soft);
  }

  .card-value {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--color-primary);
    line-height: 1;
  }

  @keyframes floatUp {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-7px); }
  }

  /* Decorative spinning accent ring */
  .accent-ring {
    position: absolute;
    top: -28px;
    left: 22%;
    width: 88px;
    height: 88px;
    border: 2.5px solid rgba(212, 165, 165, 0.38);
    border-radius: 50%;
    z-index: 1;
    animation: spin 22s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Decorative dot grid */
  .accent-dots {
    position: absolute;
    top: 48%;
    left: -28px;
    display: grid;
    grid-template-columns: repeat(3, 8px);
    gap: 9px;
    z-index: 1;
  }

  .accent-dots span {
    width: 8px;
    height: 8px;
    background: rgba(212, 165, 165, 0.42);
    border-radius: 50%;
  }

  /* ─── Tablet 768px+ ──────────────────────────────────────── */
  @media (min-width: 768px) {
    .hero {
      padding-top: 100px;
    }
  }

  /* ─── Mobile ≤ 999px: single column centered ─────────────── */
  @media (max-width: 999px) {
    .hero {
      padding-top: max(80px, env(safe-area-inset-top) + 80px);
      padding-bottom: var(--space-lg);
      align-items: flex-start;
    }

    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
      text-align: center;
    }

    .hero-inner {
      max-width: 100%;
    }

    .hero-eyebrow {
      justify-content: center;
    }

    .hero-subhead {
      margin-inline: auto;
    }

    .hero-stats {
      justify-content: center;
    }

    .hero-actions {
      justify-content: center;
    }

    /* Hide image stack on mobile — clean editorial feel */
    .hero-visual {
      display: none;
    }
  }

  /* ─── Narrow phones ≤ 480px ──────────────────────────────── */
  @media (max-width: 480px) {
    .hero {
      min-height: auto;
    }

    .hero-container {
      padding-inline: var(--space-sm);
    }

    .hero-headline {
      font-size: clamp(1.9rem, 8.5vw, 2.5rem);
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .intent-btn {
      width: 100%;
      justify-content: center;
      max-width: 280px;
    }
  }

  /* ─── Reduced motion ─────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .eyebrow-dot,
    .accent-ring,
    .floating-card {
      animation: none;
    }

    .intent-btn:hover,
    .intent-primary:hover,
    .intent-secondary:hover {
      transform: none;
    }

    .img-main img {
      transition: none;
    }
  }
</style>
